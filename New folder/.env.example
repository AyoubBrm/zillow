# ─── LedgerAI Environment Configuration ──────────────────
# Copy this file to .env and fill in values

# ─── Application ─────────────────────────────────────────
APP_NAME=LedgerAI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# ─── Security ────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=your-fernet-encryption-key-generate-with-cryptography

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ledgerai:ledgerai_dev_password@localhost:5432/ledgerai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO / S3 ─────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ledgerai
MINIO_SECRET_KEY=ledgerai_dev_password
MINIO_BUCKET_NAME=ledgerai-uploads
MINIO_USE_SSL=false

# ─── AI / LLM ───────────────────────────────────────────
# Uses local Ollama by default (free). Install: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Set to "rule_based" to use rule-based categorization (no LLM needed)
AI_CATEGORIZATION_MODE=rule_based

# ─── Email (Resend - free tier: 100 emails/day) ─────────
RESEND_API_KEY=
EMAIL_FROM=noreply@ledgerai.app
# Set to "console" to print emails to console instead of sending
EMAIL_BACKEND=console

# ─── Plaid (Bank Integration) ───────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ─── Stripe (Billing) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
